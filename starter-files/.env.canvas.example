# Copy this file to .env in the same folder as your canvas-sync skill.
# Never commit .env to git. (.env is already in .gitignore.)

# Your INSEAD email
INSEAD_EMAIL=firstname.lastname@insead.edu

# Your INSEAD password (the one you use for Canvas, CareerGlobe, etc.)
INSEAD_PASSWORD=replace_me

# Where to save downloaded course materials.
# Use forward slashes. No trailing slash.
VAULT_PATH=C:/Users/yourname/Documents/INSEAD/Courses

# Optional: where to store the cookie file between runs.
COOKIE_FILE=C:/Users/yourname/AppData/Local/Temp/canvas_cookies.json
